{
    "permissions": {
        "allow": [
            "Bash(git:*)",
            "Bash(gh:*)",
            "Bash(go:*)",
            "Bash(ls:*)",
            "Bash(find:*)",
            "Bash(grep:*)",
            "Bash(rg:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(wc:*)",
            "Bash(cat:*)",
            "Bash(echo:*)",
            "Bash(which:*)",
            "Bash(pwd:*)",
            "Bash(make:*)"
        ],
        "deny": []
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "file=\"$CLAUDE_FILE_PATH\"; if [[ \"$file\" == *.go ]]; then gofmt -w \"$file\"; command -v goimports >/dev/null 2>&1 && goimports -w \"$file\"; fi"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "file=\"$CLAUDE_FILE_PATH\"; if echo \"$file\" | grep -qE '(\\.pb\\.go|go\\.sum)$'; then echo 'BLOCK: This is a generated file. Do not edit directly. Use make protobuf or make syncdeps.' >&2; exit 2; fi"
                    }
                ]
            }
        ]
    }
}