{
    "$schema": "https://www.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(git:*)",
            "Bash(gh:*)",
            "Bash(cat:*)",
            "Bash(ls:*)",
            "Bash(find:*)",
            "Bash(grep:*)",
            "Bash(rg:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(wc:*)",
            "Bash(echo:*)",
            "Bash(which:*)",
            "Bash(cd:*)",
            "Bash(go:*)",
            "Bash(pwd:*)",
            "Bash(mkdir:*)",
            "Bash(npm:*)",
            "Bash(yarn:*)",
            "Bash(pnpm:*)"
        ],
        "deny": []
    },
    "awsAuthRefresh": "doormat aws cred-file add-profile -a aws_dschmidt_test -n sandbox",
    "env": {
        "CLAUDE_CODE_USE_BEDROCK": "1",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    },
    "model": "us.anthropic.claude-sonnet-4-6"
}