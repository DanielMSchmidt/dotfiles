#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}

# Environment state hashes — changes here trigger run_onchange re-execution
# brew leaves: {{ output "brew" "leaves" | sha256sum }}
# brew casks: {{ output "brew" "list" "--cask" "-1" | sha256sum }}
# brew taps: {{ output "brew" "tap" | sha256sum }}
# fisher plugins: {{ output "fish" "-c" "fisher list 2>/dev/null" | sha256sum }}

# Generate combined Brewfile in a temp file
brewfile=$(mktemp)
cat > "$brewfile" <<BREWEOF
{{ range .packages.universal.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.universal.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.universal.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.universal.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.work.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.work.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.work.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ else -}}
{{ range .packages.private.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.private.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.private.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.private.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
BREWEOF

# Install packages
{{ if .isWorkComputer -}}
export HOMEBREW_GITHUB_API_TOKEN='{{ onepasswordRead "op://gv2pj3dcyg2wxx3ahtvgdamp2e/ne2c6f2t3ytzfuzvdhxt4agmdu/password" "EI6GPO6VNJAVLGDDID3B75JI6E" }}'
{{ end -}}
brew bundle --file="$brewfile"

# Warn about and remove undeclared packages
undeclared=$(brew bundle cleanup --file="$brewfile" 2>/dev/null)
if [[ -n "$undeclared" ]]; then
    echo ""
    echo "WARNING: Removing packages not declared in packages.yaml:"
    echo "$undeclared"
    brew bundle cleanup --force --file="$brewfile"
    brew autoremove
fi

{{ if .isWorkComputer -}}
unset HOMEBREW_GITHUB_API_TOKEN
{{ end -}}
rm -f "$brewfile"

# Install Fisher plugins
{{ range .packages.universal.fisher -}}
fish -c 'fisher install {{ . | quote }}'
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.fisher -}}
fish -c 'fisher install {{ . | quote }}'
{{ end -}}
{{ else -}}
{{ range .packages.private.fisher -}}
fish -c 'fisher install {{ . | quote }}'
{{ end -}}
{{ end -}}

# Remove undeclared Fisher plugins
fish -c '
set expected {{ range .packages.universal.fisher }}{{ . | quote }} {{ end }}{{ if .isWorkComputer }}{{ range .packages.work.fisher }}{{ . | quote }} {{ end }}{{ else }}{{ range .packages.private.fisher }}{{ . | quote }} {{ end }}{{ end }}
if test (count $expected) -gt 0
    set expected_lower
    for e in $expected
        set -a expected_lower (string lower $e)
    end
    for plugin in (fisher list)
        if not contains -- (string lower $plugin) $expected_lower
            echo "WARNING: Removing undeclared Fisher plugin: $plugin"
            fisher remove $plugin
        end
    end
end
'

{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
# Unfortunately I did not yet find a way to order scripts so I'm inlining this. Should all be pretty much a no-op anyways.
# We use the version of the secret to determine if we need to update the secret
# This needs to be kept in sync with the .gitconfig file
# Secret version: {{ (onepassword "okuhh55hdfabbnwvgzomsywrxe" "gv2pj3dcyg2wxx3ahtvgdamp2e" "EI6GPO6VNJAVLGDDID3B75JI6E").version }}

# Early abort if the key is already added
if gpg --list-secret-keys | grep -q {{ onepasswordRead "op://gv2pj3dcyg2wxx3ahtvgdamp2e/okuhh55hdfabbnwvgzomsywrxe/id" "EI6GPO6VNJAVLGDDID3B75JI6E" }}; then
    echo "GPG key is present already"
else
    # EOF the key into a temporary file

    tmpDir=$(mktemp -d)
    tmpFile="${tmpDir}/private.key"

    # Manually use the onepassword command to get the file
    op read --out-file $tmpFile op://gv2pj3dcyg2wxx3ahtvgdamp2e/okuhh55hdfabbnwvgzomsywrxe/gmail.key --account "EI6GPO6VNJAVLGDDID3B75JI6E"

    # Import the key
    gpg --import $tmpFile
fi

# Also inlined sub-script depending on a dependency

# hash of the mise config file, used to determine if we need to rerun this script
# mise/config.toml hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

fish -c 'mise install -y'
{{ end -}}

fish -c "tide configure --auto --style=Rainbow --prompt_colors='True color' --show_time='24-hour format' --rainbow_prompt_separators=Angled --powerline_prompt_heads=Sharp --powerline_prompt_tails=Flat --powerline_prompt_style='Two lines, character and frame' --prompt_connection=Disconnected --powerline_right_prompt_frame=No --prompt_connection_andor_frame_color=Light --prompt_spacing=Sparse --icons='Few icons' --transient=No" > /dev/null 2>&1

# fish -c 'sudo xcodebuild -license'
